# Copie este arquivo para .env e preencha (o .env é ignorado pelo git).
# O servidor carrega via dotenv (server/index.ts).

# Porta do servidor (API + client na mesma porta)
PORT=5000

# ---------- IA narradora + moderação ----------
# "cloud" usa a API da Anthropic; "local" usa um endpoint OpenAI-compatível
# (Ollama, LM Studio). Sem chave configurada, a narração por IA fica
# indisponível e a moderação cai no fallback heurístico por palavras-chave.
AI_PROVIDER=cloud

# Cloud: sua chave da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Cloud: id real de modelo da Anthropic. O padrão do código
# ("claude_haiku_4_5") era o nome interno do proxy do Perplexity Labs
# e NÃO funciona com uma chave própria — defina um id válido:
AI_MODEL=claude-haiku-4-5-20251001

# Local (AI_PROVIDER=local): endpoint e modelo do servidor local
# AI_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.1
